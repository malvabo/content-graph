# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Production URL — set this in Vercel env vars and add it to Supabase Auth → Redirect URLs.
# Prevents OAuth redirects from using a dynamic preview origin that isn't in the allowlist.
VITE_APP_URL=https://your-app.vercel.app

# Optional: Anthropic API key (users can also set this in Settings)
VITE_ANTHROPIC_API_KEY=
