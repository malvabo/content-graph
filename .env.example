# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: Anthropic API key (users can also set this in Settings)
VITE_ANTHROPIC_API_KEY=

# First-party AI proxy (api/claude.ts) — required for iOS app
ANTHROPIC_API_KEY=
# Secret for signing iOS session tokens — generate with: openssl rand -hex 32
JWT_SECRET=
